# Copia este archivo a `.env` y rellena los valores.
# `.env` está en .gitignore y NUNCA debe subirse: el repositorio es público.
#
# En producción (Dokploy) estas variables NO salen de aquí: se pegan en
# App -> Environment de la interfaz. Ver DEPLOY.md.

# --- Base de datos (desarrollo local con docker compose) ---
POSTGRES_USER=zonaxtrema
POSTGRES_PASSWORD=zonaxtrema
POSTGRES_DB=zonaxtrema
# Puerto expuesto en el host (5433 para no chocar con un Postgres local en 5432)
POSTGRES_PORT=5433

# Conexión completa. Si tiene valor, gana sobre los POSTGRES_* de arriba.
# Es la forma en que Dokploy entrega la base; en local se deja vacía.
DATABASE_URL=

# --- API ---
API_PORT=8000
SECRET_KEY=cambiar-en-produccion-usar-openssl-rand-hex-32
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
# URL que ve el cliente desde fuera: es la de los enlaces de WhatsApp y los QR.
# En producción, el dominio real, o no abrirán desde el celular del cliente.
PUBLIC_BASE_URL=http://localhost:8000

# Zona horaria del negocio. Define dónde empieza y termina "el día" en el
# dashboard, los reportes, los arqueos y la fecha de emisión ante SUNAT.
TIMEZONE=America/Lima

# --- Seed inicial (permisos, roles y administrador) ---
# Si no se define ADMIN_PASSWORD, el seed genera una y la imprime en el log.
RUN_SEED=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# --- FactPro / facturación electrónica ---
# Sin token, el sistema emite en MODO SIMULACIÓN: los comprobantes no tienen
# validez ante SUNAT. Con token (demo o producción) las emisiones son reales.
FACTPRO_BASE_URL=https://api.factpro.la/api/v3
FACTPRO_TOKEN=

# Consulta RENIEC/SUNAT por DNI/RUC (producto aparte de FactPro, token propio).
FACTPRO_CONSULTAS_URL=https://consultas.factpro.la/api/v1
FACTPRO_CONSULTAS_TOKEN=

# --- Emisor (debe coincidir con la cuenta dueña del FACTPRO_TOKEN, que firma) ---
# Si no se define, se usan los valores por defecto de config.py.
EMISOR_RUC=
EMISOR_RAZON_SOCIAL=
