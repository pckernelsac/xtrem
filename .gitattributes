# Normalización de finales de línea.
# El repo se edita en Windows pero se ejecuta en contenedores Linux: un script
# con CRLF falla con "no such file or directory" (el shebang se lleva el \r),
# que es un error muy difícil de leer.
* text=auto eol=lf

*.sh    text eol=lf
Dockerfile text eol=lf
*.conf  text eol=lf

# Binarios: que git no los toque
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.gz    binary
*.xlsx  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
